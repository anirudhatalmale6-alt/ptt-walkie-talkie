<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="PTT Walkie"
        android:supportsRtl="true"
        android:theme="@style/Theme.PTTWalkie"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".PTTService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <receiver
            android:name=".PTTBroadcastReceiver"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="com.android.action.SIDE_KEY_DOWN" />
                <action android:name="com.android.action.SIDE_KEY_UP" />
                <action android:name="com.android.action.SIDE_KEY" />
                <action android:name="android.intent.action.PTT.down" />
                <action android:name="android.intent.action.PTT.up" />
                <action android:name="android.intent.action.PTT" />
                <action android:name="android.intent.action.SIDE_KEY_DOWN" />
                <action android:name="android.intent.action.SIDE_KEY_UP" />
                <action android:name="android.intent.action.SIDE_KEY" />
                <action android:name="com.xptt.pttbtn.down" />
                <action android:name="com.xptt.pttbtn.up" />
                <action android:name="ptt.key.down" />
                <action android:name="ptt.key.up" />
                <action android:name="com.ptt.BUTTON_DOWN" />
                <action android:name="com.ptt.BUTTON_UP" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
