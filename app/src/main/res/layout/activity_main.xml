<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎙️ PTT Walkie Talkie"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="עובד מכל מקום באינטרנט"
        android:textColor="#888888"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginTop="2dp" />

    <!-- Group Number -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="מספר קבוצה"
        android:textColor="#cccccc"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <EditText
            android:id="@+id/etGroupNumber"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/edit_bg"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:hint="1"
            android:text="1"
            android:inputType="number"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="10dp" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="התחבר לקבוצה"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#2E7D32"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="לא מחובר"
        android:textColor="#FF5252"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginTop="10dp" />

    <!-- Online count -->
    <TextView
        android:id="@+id/tvOnline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#aaaaaa"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="2dp" />

    <!-- Transmitting indicator -->
    <TextView
        android:id="@+id/tvTransmitting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FF9800"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="4dp" />

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Big PTT Button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center">

        <Button
            android:id="@+id/btnPTT"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center"
            android:text="🎤\n\nלחץ כאן לשידור\n\nPTT"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444466"
            android:enabled="false"
            android:stateListAnimator="@null" />
    </FrameLayout>

    <!-- Hint -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="לחץ והחזק את הכפתור כדי לשדר\nאו השתמש במקש PTT הפיזי במכשיר"
        android:textColor="#666666"
        android:textSize="12sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

</LinearLayout>
